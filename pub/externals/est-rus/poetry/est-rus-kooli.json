  "lines": [
    {
      "A": "Kooli",
      "B": "В школу"
    },
    {
      "A": "Kooli läheb suur ja väike,",
      "B": "В школу идёт большой и маленький,"
    },
    {
      "A": "Lasteaeda pisem veel,",
      "B": "А самый маленький ещё в детский сад,"
    },
    {
      "A": "Ühele loob silma läike,",
      "B": "У одного появляется блеск в глазах,"
    },
    {
      "A": "Teisel jälle rõõmus meel,",
      "B": "У другого снова радостное настроение,"
    },
    {
      "A": "Sest on kooli tulla hea",
      "B": "Потому что хорошо приходить в школу"
    },
    {
      "A": "Suure naeratusega,",
      "B": "С большой улыбкой,"
    },
    {
      "A": "Õpetajat armsat pea",
      "B": "Дорогого учителя помни"
    },
    {
      "A": "Meeles lilleõiega.",
      "B": "С цветком в памяти."
    }
  ]
}
