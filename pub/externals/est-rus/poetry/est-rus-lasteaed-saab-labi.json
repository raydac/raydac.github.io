  "lines": [
    {
      "A": "Lasteaed saab läbi",
      "B": "Детский сад заканчивается"
    },
    {
      "A": "Oli rõõme, oli kurbust,",
      "B": "Были радости, была грусть,"
    },
    {
      "A": "Unejonni, palju uudsust,",
      "B": "Капризы перед сном, много нового,"
    },
    {
      "A": "Uusi sõpru, õpetajaid,",
      "B": "Новые друзья, воспитатели,"
    },
    {
      "A": "Kes kõik saatsid lõpetajaid",
      "B": "Которые все провожали выпускников"
    },
    {
      "A": "Kooli, head vaid soovides",
      "B": "В школу, желая только добра"
    },
    {
      "A": "Ning mitte nutta proovides",
      "B": "И стараясь не плакать"
    }
  ]
